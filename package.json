{
  "name": "pif",
  "version": "0.1.0",
  "private": true,
  "description": "Pi package for creating and enforcing frontend design style guides.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pif",
    "styleguide",
    "design-system",
    "frontend"
  ],
  "files": [
    "design-system-blueprint/",
    "design-system-blueprint-appendices/",
    "extensions/",
    "prompts/",
    "scripts/",
    "skills/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions/pif/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "smoke-test": "node scripts/smoke-test.mjs",
    "smoke-test:full": "node scripts/smoke-test.mjs --full",
    "validate:example": "node templates/validators/validate-all.mjs examples/mailpilot-design-guide"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  }
}
